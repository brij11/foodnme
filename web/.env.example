# foodnme — environment variables (TECHNICAL-REQUIREMENTS.md §11)
# Copy to .env.local for local dev. NEXT_PUBLIC_* are inlined into the client bundle.

# Supabase (local stack values come from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ZeptoMail (Zoho) — transactional email
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=
ZEPTOMAIL_FROM_NAME=
# Founder inbox that receives service-inquiry notifications
ADMIN_EMAIL=

# Analytics (consent-gated, §9.1) — optional
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry
SENTRY_DSN=
# CI-only, for source-map upload
SENTRY_AUTH_TOKEN=

# Cloudflare Turnstile (anti-spam on public writes, §9.6)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — idempotency dedupe (§6.1). Optional; routes degrade gracefully if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
